# ─────────────────────────────────────────────────────────────────────────────
# McEvoy Racing — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── SANITY ────────────────────────────────────────────────────────────────────
# Found at: sanity.io/manage → your project → API

# Your Sanity project ID (looks like: abc12def)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Your Sanity dataset (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (leave as-is)
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API token — create at sanity.io/manage → API → Tokens
# Give it "Editor" permissions. Used for webhook revalidation.
SANITY_API_TOKEN=your_sanity_api_token_here

# ── VERCEL REVALIDATION ───────────────────────────────────────────────────────
# A secret string YOU make up — used to secure the revalidation webhook.
# Can be anything, e.g.: openssl rand -hex 32
# Add this same value in Sanity webhook config as the "HTTP Header" secret.
SANITY_REVALIDATE_SECRET=your_secret_string_here

# ── NEXT.JS ───────────────────────────────────────────────────────────────────
# Your live site URL (no trailing slash). Used for absolute URLs.
NEXT_PUBLIC_SITE_URL=https://mcevoyracing.com.au
